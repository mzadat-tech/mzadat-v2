# ═══════════════════════════════════════════
# Mzadat Platform — Environment Variables
# ═══════════════════════════════════════════

# ── Database (Prisma) ──
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres?schema=public"
DIRECT_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres?schema=public"
DATABASE_PASSWORD=+YbZEX5Mvny@fj6

# ── Supabase (Auth, Realtime, Storage) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx

# ── Apps ──
NEXT_PUBLIC_WEB_URL=http://localhost:8001
NEXT_PUBLIC_ADMIN_URL=http://localhost:8002
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Supabase Storage (S3-compatible) ──
SUPABASE_STORAGE_ENDPOINT=https://xxxx.supabase.co/storage/v1/s3
SUPABASE_STORAGE_BUCKET=media
SUPABASE_STORAGE_KEY=your-storage-access-key
SUPABASE_STORAGE_SECRET=your-storage-secret-key
SUPABASE_STORAGE_REGION=us-east-1

# ── Auth Providers ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ── Payment Gateways (dynamic — managed via admin panel, stored encrypted in DB) ──
# No static keys needed here. Add gateways via /admin/payment-gateways.

# ── Email (Resend) ──
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@mzadat.om

# ── Error Monitoring ──
SENTRY_DSN=https://xxxx@sentry.io/xxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ── reCAPTCHA ──
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── API ──
API_PORT=8080
CORS_ORIGINS=http://localhost:8001,http://localhost:8002

# ── JWT (copy from Supabase Dashboard → Settings → API → JWT Settings) ──
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-at-least-32-chars

# ── Encryption (used by pgcrypto to encrypt payment gateway secrets) ──
ENCRYPTION_KEY=generate-a-strong-random-32-char-key

# ── Timezone ──
TZ=Asia/Muscat
