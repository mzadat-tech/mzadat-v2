// Prisma schema for Mzadat Auction Platform
// Database: Supabase PostgreSQL
// Migrations managed via Prisma Migrate

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgcrypto]
}

// ═══════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════

enum UserRole {
  customer
  merchant
  admin
  super_admin
}

enum UserStatus {
  active
  inactive
  suspended
  pending_verification
}

enum RegisterType {
  individual
  company
}

enum ProductSaleType {
  auction
  direct
}

enum ProductStatus {
  draft
  pending
  published
  inactive
  closed
}

enum ProductScheduleType {
  default
  scheduled
}

enum DepositType {
  fixed
  percentage
}

enum OrderType {
  bid
  purchase
}

enum OrderStatus {
  processing
  win
  rejected
  completed
  on_hold
  delivered
  refunded
  shipped
}

enum PaymentStatus {
  partial
  unpaid
  paid
}

enum WalletTxType {
  deposit
  bid
  purchase
  withdraw
  return
  refund
  bid_final_payment
  admin_adjustment
  commission
  hold
  release
  fee
}

enum WalletTxStatus {
  pending
  completed
  rejected
  on_hold
  cancelled
}

enum WithdrawalStatus {
  pending
  approved
  rejected
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

enum GroupStatus {
  upcoming
  active
  closed
  cancelled
}

// BlogStatus and PageStatus enums — see CMS tables migration
// (prisma/migrations/20260306100000_add_cms_tables/migration.sql)

enum ContentStatus {
  active
  inactive
}

// ═══════════════════════════════════════════
// LOCATION TABLES
// ═══════════════════════════════════════════

model Country {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      Json          @default("{}") @db.JsonB
  code      String        @unique // OM, AE, etc.
  phoneCode String?       @map("phone_code")
  status    ContentStatus @default(active)

  states          State[]
  profileCountry  Profile[] @relation("profile_country")
  billingCountry  Order[]   @relation("billing_country")
  shippingCountry Order[]   @relation("shipping_country")

  @@map("countries")
}

model State {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  countryId String        @map("country_id") @db.Uuid
  name      Json          @default("{}") @db.JsonB
  code      String?
  status    ContentStatus @default(active)

  country       Country   @relation(fields: [countryId], references: [id], onDelete: Cascade)
  cities        City[]
  profileState  Profile[] @relation("profile_state")
  billingState  Order[]   @relation("billing_state")
  shippingState Order[]   @relation("shipping_state")

  @@index([countryId])
  @@map("states")
}

model City {
  id      String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stateId String        @map("state_id") @db.Uuid
  name    Json          @default("{}") @db.JsonB
  status  ContentStatus @default(active)

  state        State     @relation(fields: [stateId], references: [id], onDelete: Cascade)
  profileCity  Profile[] @relation("profile_city")
  billingCity  Order[]   @relation("billing_city")
  shippingCity Order[]   @relation("shipping_city")

  @@index([stateId])
  @@map("cities")
}

// ═══════════════════════════════════════════
// CORPORATE DOMAINS
// ═══════════════════════════════════════════

model CorporateDomain {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domain        String        @unique // 'petrooman.com'
  companyName   String        @map("company_name")
  companyNameAr String?       @map("company_name_ar")
  adminUserId   String?       @map("admin_user_id") @db.Uuid
  maxBidLimit   Decimal?      @map("max_bid_limit") @db.Decimal(12, 3)
  isVerified    Boolean       @default(false) @map("is_verified")
  status        ContentStatus @default(inactive)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  adminUser Profile?  @relation("corporate_admin", fields: [adminUserId], references: [id])
  profiles  Profile[] @relation("corporate_members")

  @@map("corporate_domains")
}

// ═══════════════════════════════════════════
// USER PROFILES
// ═══════════════════════════════════════════

model Profile {
  id         String       @id @db.Uuid // Links to Supabase auth.users(id)
  customId   String       @unique @map("custom_id") // C0001, MC0001
  role       UserRole     @default(customer)
  status     UserStatus   @default(pending_verification)
  registerAs RegisterType @default(individual) @map("register_as")

  // Personal info (bilingual)
  firstName   String  @map("first_name")
  lastName    String  @map("last_name")
  firstNameAr String? @map("first_name_ar")
  lastNameAr  String? @map("last_name_ar")
  email       String  @unique
  phone       String?
  image       String? // Avatar path in storage

  // Identity
  individualId String? @map("individual_id") // National / Civil ID
  companyName  String? @map("company_name")
  companyId    String? @map("company_id") // Commercial registration

  // Location
  countryId String? @map("country_id") @db.Uuid
  stateId   String? @map("state_id") @db.Uuid
  cityId    String? @map("city_id") @db.Uuid
  address   String?
  zipCode   String? @map("zip_code")

  // VIP & Flags
  isVip         Boolean @default(false) @map("is_vip")
  emailVerified Boolean @default(false) @map("email_verified")

  // Financial
  walletBalance          Decimal @default(0.000) @map("wallet_balance") @db.Decimal(12, 3)
  walletBalanceEncrypted Bytes?  @map("wallet_balance_encrypted")

  // Corporate domain
  corporateDomainId String? @map("corporate_domain_id") @db.Uuid

  // Metadata
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  country         Country?         @relation("profile_country", fields: [countryId], references: [id])
  state           State?           @relation("profile_state", fields: [stateId], references: [id])
  city            City?            @relation("profile_city", fields: [cityId], references: [id])
  corporateDomain CorporateDomain? @relation("corporate_members", fields: [corporateDomainId], references: [id])

  stores              Store[]
  merchantProducts    Product[]           @relation("product_merchant")
  orders              Order[]             @relation("order_user")
  merchantOrders      Order[]             @relation("order_merchant")
  bids                BidHistory[]        @relation("bid_user")
  merchantBids        BidHistory[]        @relation("bid_merchant")
  walletTransactions  WalletTransaction[]
  bankDeposits        BankDeposit[]       @relation("bank_deposit_user")
  reviewedDeposits    BankDeposit[]       @relation("bank_deposit_reviewer")
  withdrawals         Withdrawal[]        @relation("withdrawal_user")
  reviewedWithdrawals Withdrawal[]        @relation("withdrawal_reviewer")
  supportTickets      SupportTicket[]
  ticketReplies       TicketReply[]
  notifications       Notification[]
  watchlist           Watchlist[]
  paymentInfo         UserPaymentInfo[]
  auditLogs           AuditLog[]
  productReviews      ProductReview[]
  deletedBidLogs      DeletedBidLog[]
  groups              Group[]
  corporateAdmin      CorporateDomain[]   @relation("corporate_admin")

  @@index([role])
  @@index([status])
  @@index([email])
  @@index([customId])
  @@index([corporateDomainId])
  @@map("profiles")
}

// ═══════════════════════════════════════════
// STORES
// ═══════════════════════════════════════════

model Store {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId        String        @map("owner_id") @db.Uuid
  slug           String        @unique
  name           Json          @default("{}") @db.JsonB // {"en": "...", "ar": "..."}
  description    Json?         @default("{}") @db.JsonB
  email          String?
  phone          String?
  address        String?
  logo           String?
  coverImage     String?       @map("cover_image")
  socialLinks    Json?         @default("{}") @map("social_links") @db.JsonB
  commissionRate Decimal?      @default(0.00) @map("commission_rate") @db.Decimal(5, 2)
  vatApplicable  Boolean       @default(false) @map("vat_applicable")
  vatRate        Decimal?      @default(5.00) @map("vat_rate") @db.Decimal(5, 2)
  status         ContentStatus @default(active)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  owner    Profile   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products Product[]
  groups   Group[]

  @@index([ownerId])
  @@index([slug])
  @@map("stores")
}

// ═══════════════════════════════════════════
// CATEGORIES
// ═══════════════════════════════════════════

model Category {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId    String?       @map("parent_id") @db.Uuid
  slug        String        @unique
  name        Json          @default("{}") @db.JsonB
  description Json?         @default("{}") @db.JsonB
  image       String?
  icon        String?
  sortOrder   Int           @default(0) @map("sort_order")
  status      ContentStatus @default(active)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  parent   Category?  @relation("category_tree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("category_tree")
  products Product[]

  @@index([parentId])
  @@index([slug])
  @@index([status])
  @@map("categories")
}

// ═══════════════════════════════════════════
// GROUPS
// ═══════════════════════════════════════════

model Group {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId             String?     @map("store_id") @db.Uuid
  merchantId          String      @map("merchant_id") @db.Uuid
  name                Json        @default("{}") @db.JsonB
  description         Json?       @default("{}") @db.JsonB
  image               String?
  startDate           DateTime    @map("start_date") @db.Timestamptz
  endDate             DateTime    @map("end_date") @db.Timestamptz
  inspectionStartDate DateTime?   @map("inspection_start_date") @db.Timestamptz
  inspectionEndDate   DateTime?   @map("inspection_end_date") @db.Timestamptz
  minDeposit          Decimal     @default(0.000) @map("min_deposit") @db.Decimal(12, 3)
  status              GroupStatus @default(upcoming)
  createdAt           DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  store    Store?    @relation(fields: [storeId], references: [id], onDelete: SetNull)
  merchant Profile   @relation(fields: [merchantId], references: [id])
  products Product[]
  orders   Order[]

  @@index([storeId])
  @@index([merchantId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("groups")
}

// ═══════════════════════════════════════════
// PRODUCTS
// ═══════════════════════════════════════════

model Product {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId String  @map("merchant_id") @db.Uuid
  storeId    String? @map("store_id") @db.Uuid
  categoryId String? @map("category_id") @db.Uuid
  groupId    String? @map("group_id") @db.Uuid

  // Core
  slug             String  @unique
  name             Json    @default("{}") @db.JsonB
  description      Json?   @default("{}") @db.JsonB
  shortDescription Json?   @default("{}") @map("short_description") @db.JsonB
  featureImage     String? @map("feature_image")
  quantity         Int     @default(1)

  // Sale type
  saleType     ProductSaleType     @default(auction) @map("sale_type")
  scheduleType ProductScheduleType @default(default) @map("schedule_type")

  // Pricing
  price        Decimal  @default(0.000) @db.Decimal(12, 3)
  salePrice    Decimal? @map("sale_price") @db.Decimal(12, 3)
  minBidPrice  Decimal  @default(0.000) @map("min_bid_price") @db.Decimal(12, 3)
  reservePrice Decimal? @map("reserve_price") @db.Decimal(12, 3)
  currentBid   Decimal  @default(0.000) @map("current_bid") @db.Decimal(12, 3)

  // Bid increments (tiered)
  bidIncrement1 Decimal  @default(1.000) @map("bid_increment_1") @db.Decimal(12, 3)
  bidIncrement2 Decimal? @map("bid_increment_2") @db.Decimal(12, 3)
  bidIncrement3 Decimal? @map("bid_increment_3") @db.Decimal(12, 3)
  bidIncrement4 Decimal? @map("bid_increment_4") @db.Decimal(12, 3)

  // Deposit
  minDeposit     Decimal     @default(0.000) @map("min_deposit") @db.Decimal(12, 3)
  minDepositType DepositType @default(fixed) @map("min_deposit_type")

  // Schedule
  startDate       DateTime? @map("start_date") @db.Timestamptz
  endDate         DateTime? @map("end_date") @db.Timestamptz
  originalEndDate DateTime? @map("original_end_date") @db.Timestamptz

  // Anti-sniping
  snipeExtensionSeconds    Int @default(120) @map("snipe_extension_seconds")
  maxSnipeExtensionMinutes Int @default(30) @map("max_snipe_extension_minutes")
  totalExtensions          Int @default(0) @map("total_extensions")

  // Location
  location        String?
  inspectionNotes String? @map("inspection_notes")

  // SEO
  metaTitle       Json? @default("{}") @map("meta_title") @db.JsonB
  metaKeywords    Json? @default("{}") @map("meta_keywords") @db.JsonB
  metaDescription Json? @default("{}") @map("meta_description") @db.JsonB

  // Counters (cached)
  bidCount  Int @default(0) @map("bid_count")
  viewCount Int @default(0) @map("view_count")

  status    ProductStatus @default(draft)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime?     @map("deleted_at") @db.Timestamptz

  // Relations
  merchant       Profile                @relation("product_merchant", fields: [merchantId], references: [id])
  store          Store?                 @relation(fields: [storeId], references: [id])
  category       Category?              @relation(fields: [categoryId], references: [id])
  group          Group?                 @relation(fields: [groupId], references: [id], onDelete: SetNull)
  gallery        ProductGallery[]
  specifications ProductSpecification[]
  reviews        ProductReview[]
  orders         Order[]
  bids           BidHistory[]
  walletTx       WalletTransaction[]
  watchlist      Watchlist[]

  @@index([merchantId])
  @@index([categoryId])
  @@index([groupId])
  @@index([status])
  @@index([saleType])
  @@index([slug])
  @@index([startDate, endDate])
  @@index([status, saleType, startDate, endDate])
  @@index([deletedAt, createdAt(sort: Desc)])
  @@map("products")
}

model ProductGallery {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  image     String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_galleries")
}

model ProductSpecification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  label     Json     @default("{}") @db.JsonB // {"en": "Color", "ar": "اللون"}
  value     Json     @default("{}") @db.JsonB // {"en": "Red", "ar": "أحمر"}
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_specifications")
}

model ProductReview {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId  String        @map("product_id") @db.Uuid
  userId     String        @map("user_id") @db.Uuid
  rating     Int           @db.SmallInt
  comment    String?
  adminReply String?       @map("admin_reply")
  status     ContentStatus @default(active)
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    Profile @relation(fields: [userId], references: [id])

  @@index([productId])
  @@map("product_reviews")
}

// ═══════════════════════════════════════════
// ORDERS
// ═══════════════════════════════════════════

model Order {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNumber String  @unique @map("order_number") // MZD-2026-0001
  userId      String  @map("user_id") @db.Uuid
  productId   String  @map("product_id") @db.Uuid
  merchantId  String  @map("merchant_id") @db.Uuid
  groupId     String? @map("group_id") @db.Uuid

  type          OrderType
  status        OrderStatus   @default(processing)
  paymentStatus PaymentStatus @default(unpaid) @map("payment_status")

  // Amounts
  bidAmount        Decimal @default(0.000) @map("bid_amount") @db.Decimal(12, 3)
  amount           Decimal @default(0.000) @db.Decimal(12, 3)
  taxAmount        Decimal @default(0.000) @map("tax_amount") @db.Decimal(12, 3)
  commissionAmount Decimal @default(0.000) @map("commission_amount") @db.Decimal(12, 3)
  totalAmount      Decimal @default(0.000) @map("total_amount") @db.Decimal(12, 3)

  // Deposit
  depositAmount Decimal @default(0.000) @map("deposit_amount") @db.Decimal(12, 3)
  depositPaid   Boolean @default(false) @map("deposit_paid")

  // Billing snapshot
  billingName      String? @map("billing_name")
  billingEmail     String? @map("billing_email")
  billingPhone     String? @map("billing_phone")
  billingAddress   String? @map("billing_address")
  billingCountryId String? @map("billing_country") @db.Uuid
  billingStateId   String? @map("billing_state") @db.Uuid
  billingCityId    String? @map("billing_city") @db.Uuid

  // Shipping
  shippingName      String? @map("shipping_name")
  shippingAddress   String? @map("shipping_address")
  shippingCountryId String? @map("shipping_country") @db.Uuid
  shippingStateId   String? @map("shipping_state") @db.Uuid
  shippingCityId    String? @map("shipping_city") @db.Uuid

  // Restriction
  isRestricted Boolean @default(false) @map("is_restricted")

  // Payment method
  paymentMethod String? @map("payment_method")
  transactionId String? @map("transaction_id")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user            Profile             @relation("order_user", fields: [userId], references: [id])
  product         Product             @relation(fields: [productId], references: [id])
  merchant        Profile             @relation("order_merchant", fields: [merchantId], references: [id])
  group           Group?              @relation(fields: [groupId], references: [id])
  billingCountry  Country?            @relation("billing_country", fields: [billingCountryId], references: [id])
  billingState    State?              @relation("billing_state", fields: [billingStateId], references: [id])
  billingCity     City?               @relation("billing_city", fields: [billingCityId], references: [id])
  shippingCountry Country?            @relation("shipping_country", fields: [shippingCountryId], references: [id])
  shippingState   State?              @relation("shipping_state", fields: [shippingStateId], references: [id])
  shippingCity    City?               @relation("shipping_city", fields: [shippingCityId], references: [id])
  bids            BidHistory[]
  walletTx        WalletTransaction[]

  @@index([userId])
  @@index([productId])
  @@index([merchantId])
  @@index([status])
  @@index([orderNumber])
  @@index([type])
  @@map("orders")
}

// ═══════════════════════════════════════════
// BID HISTORY
// ═══════════════════════════════════════════

model BidHistory {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String?   @map("order_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  productId   String    @map("product_id") @db.Uuid
  merchantId  String    @map("merchant_id") @db.Uuid
  amount      Decimal   @db.Decimal(12, 3)
  orderNumber String?   @map("order_number")
  isWinning   Boolean   @default(false) @map("is_winning")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  order    Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  user     Profile @relation("bid_user", fields: [userId], references: [id])
  product  Product @relation(fields: [productId], references: [id])
  merchant Profile @relation("bid_merchant", fields: [merchantId], references: [id])

  @@index([productId])
  @@index([userId])
  @@index([productId, amount(sort: Desc)])
  @@index([productId, isWinning])
  @@map("bid_history")
}

model DeletedBidLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bidId        String   @map("bid_id") @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  amount       Decimal  @db.Decimal(12, 3)
  deletedBy    String   @map("deleted_by") @db.Uuid
  reason       String?
  originalData Json     @map("original_data") @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  deletedByUser Profile @relation(fields: [deletedBy], references: [id])

  @@map("deleted_bid_log")
}

// ═══════════════════════════════════════════
// WALLET & FINANCE
// ═══════════════════════════════════════════

model WalletTransaction {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referenceNumber String  @unique @map("reference_number") // WTX-2026-000001
  userId          String  @map("user_id") @db.Uuid
  orderId         String? @map("order_id") @db.Uuid
  productId       String? @map("product_id") @db.Uuid

  type   WalletTxType
  status WalletTxStatus @default(pending)

  amount          Decimal @default(0.000) @db.Decimal(12, 3)
  adminCommission Decimal @default(0.000) @map("admin_commission") @db.Decimal(12, 3)
  merchantAmount  Decimal @default(0.000) @map("merchant_amount") @db.Decimal(12, 3)
  taxAmount       Decimal @default(0.000) @map("tax_amount") @db.Decimal(12, 3)
  totalAmount     Decimal @default(0.000) @map("total_amount") @db.Decimal(12, 3)

  paymentMethod String?  @map("payment_method")
  transactionId String?  @map("transaction_id")
  gatewayAmount Decimal? @map("gateway_amount") @db.Decimal(12, 3)
  currency      String?  @default("OMR")
  proofDocument String?  @map("proof_document")
  description   String?

  // Encrypted amount for tamper detection (pgcrypto)
  amountEncrypted Bytes? @map("amount_encrypted")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user         Profile       @relation(fields: [userId], references: [id])
  order        Order?        @relation(fields: [orderId], references: [id])
  product      Product?      @relation(fields: [productId], references: [id])
  bankDeposits BankDeposit[]

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([orderId])
  @@index([referenceNumber])
  @@index([createdAt(sort: Desc)])
  @@map("wallet_transactions")
}

