// Settings model — see site_settings table in CMS migration
// and static config in packages/config/src/site.ts

// Payment gateways — credentials are encrypted at rest via pgcrypto.
// The `credentials_encrypted` column stores AES-256-encrypted JSON.
// Decryption happens only at runtime in the API layer using ENCRYPTION_KEY.
model PaymentGateway {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        Json    @default("{}") @db.JsonB // {"en": "Thawani", "ar": "ثواني"}
  code        String  @unique // 'thawani', 'stripe', 'tap', 'bank_transfer'
  provider    String // Technical provider key
  logo        String?
  description Json?   @default("{}") @db.JsonB

  // Encrypted credentials blob (JSON encrypted with pgcrypto)
  credentialsEncrypted Bytes? @map("credentials_encrypted")

  // Environment mode
  isSandbox Boolean @default(true) @map("is_sandbox")

  // Gateway-specific config (non-secret)
  supportedCurrencies String[] @default(["OMR"]) @map("supported_currencies")
  supportedMethods    String[] @default([]) @map("supported_methods") // ['card', 'apple_pay', 'google_pay']
  webhookUrl          String?  @map("webhook_url")
  extraSettings       Json?    @default("{}") @map("extra_settings") @db.JsonB

  // Ordering & visibility
  isActive  Boolean @default(false) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  // Metadata
  lastTestedAt   DateTime? @map("last_tested_at") @db.Timestamptz
  lastTestResult String?   @map("last_test_result") // 'success' | 'failed'
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  transactions PaymentTransaction[]

  @@index([code])
  @@index([isActive])
  @@map("payment_gateways")
}

// Individual payment transactions processed through a gateway
model PaymentTransaction {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gatewayId   String  @map("gateway_id") @db.Uuid
  gatewayCode String  @map("gateway_code") // denormalized for fast queries
  externalId  String? @map("external_id") // gateway's transaction ID
  orderId     String? @map("order_id") @db.Uuid
  userId      String? @map("user_id") @db.Uuid

  // Amounts
  amount     Decimal  @db.Decimal(12, 3)
  currency   String   @default("OMR")
  gatewayFee Decimal? @map("gateway_fee") @db.Decimal(12, 3)

  // Flow
  type         String // 'charge', 'refund', 'payout'
  status       String  @default("pending") // 'pending', 'processing', 'success', 'failed', 'refunded'
  errorCode    String? @map("error_code")
  errorMessage String? @map("error_message")

  // Raw gateway response
  gatewayRequest  Json? @map("gateway_request") @db.JsonB
  gatewayResponse Json? @map("gateway_response") @db.JsonB

  // Metadata
  metadata    Json?     @default("{}") @db.JsonB
  ipAddress   String?   @map("ip_address")
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  gateway PaymentGateway @relation(fields: [gatewayId], references: [id])

  @@index([gatewayId])
  @@index([gatewayCode])
  @@index([externalId])
  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("payment_transactions")
}

// Legacy / simple payment methods (bank transfer, wallet, cash on delivery)
model PaymentMethod {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  methodName    String        @map("method_name")
  slug          String        @unique
  credentials   Json?         @default("{}") @db.JsonB
  isSandbox     Boolean       @default(true) @map("is_sandbox")
  currency      String?       @default("OMR")
  logo          String?
  extraSettings Json?         @default("{}") @map("extra_settings") @db.JsonB
  status        ContentStatus @default(inactive)
  sortOrder     Int           @default(0) @map("sort_order")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("payment_methods")
}

model Currency {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  symbol       String
  code         String        @unique // OMR, USD
  exchangeRate Decimal       @default(1.000000) @map("exchange_rate") @db.Decimal(12, 6)
  isDefault    Boolean       @default(false) @map("is_default")
  status       ContentStatus @default(active)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("currencies")
}

